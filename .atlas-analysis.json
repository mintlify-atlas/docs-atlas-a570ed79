  "keyFeatures": [
    "Infinite scrolling with Intersection Observer",
    "TanStack Query for data caching and state management",
    "Material-UI components with custom theming",
    "Responsive design with mobile menu",
    "Dynamic search parameters for pagination control",
    "Firebase hosting deployment"
  ],
  "publicApiSurface": [
    "usePokemons() - Custom hook for Pokémon data fetching",
    "getPokemonsAction(options) - Action to fetch Pokémon from API",
    "pokeApi - Configured Axios instance",
    "CardPokemon - Pokémon card component",
    "CardGridPokemon - Grid layout component",
    "HeaderControls - Navigation controls component",
    "PokemonLayout - Main layout wrapper",
    "HomePage - Main page with infinite scroll"
